{
  "info": {
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "name": "Orbital Guardian API",
    "description": "Coleção completa da Orbital Guardian API. Execute os requests na ordem dos folders — o login salva o token automaticamente e cada POST salva o ID da resposta nas variáveis da coleção.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      { "key": "token", "value": "{{token}}", "type": "string" }
    ]
  },
  "variable": [
    { "key": "baseUrl",        "value": "http://localhost:8080", "type": "string" },
    { "key": "token",          "value": "", "type": "string" },
    { "key": "operatorId",     "value": "", "type": "string" },
    { "key": "satelliteId",    "value": "", "type": "string" },
    { "key": "debrisId",       "value": "", "type": "string" },
    { "key": "stationId",      "value": "", "type": "string" },
    { "key": "conjunctionId",  "value": "", "type": "string" },
    { "key": "alertId",        "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "1 — Auth",
      "item": [
        {
          "name": "01 · Login (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.token) {",
                  "    pm.collectionVariables.set('token', json.token);",
                  "    console.log('Token salvo:', json.token.substring(0, 30) + '...');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"email\": \"admin@orbitalguardian.com\",\n  \"password\": \"Admin@123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "02 · Register (Operator)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"email\": \"operator@orbitalguardian.com\",\n  \"password\": \"Operator@123\",\n  \"fullName\": \"Carlos Operador\",\n  \"role\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            }
          }
        }
      ]
    },
    {
      "name": "2 — Users",
      "item": [
        {
          "name": "03 · GET All Users",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var json = pm.response.json();",
                  "var op = json.find(function(u) { return u.email === 'operator@orbitalguardian.com'; });",
                  "if (op) {",
                  "    pm.collectionVariables.set('operatorId', op.id);",
                  "    console.log('operatorId salvo:', op.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/users",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users"]
            }
          }
        },
        {
          "name": "04 · GET User by ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/users/{{operatorId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "{{operatorId}}"]
            }
          }
        },
        {
          "name": "05 · PUT Update User",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"fullName\": \"Carlos Silva\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users/{{operatorId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "{{operatorId}}"]
            }
          }
        }
      ]
    },
